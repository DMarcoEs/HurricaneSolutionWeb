# ============================================
# .env.example — Hurricane Solution Web
# ============================================
# Copia este archivo a .env y completa los valores reales.
# El .env real NUNCA se commitea (está en .gitignore).
# En Hostinger, estos valores se configuran desde el panel
# de "Variables de entorno" de la app Node.js.
# ============================================

# ----- Entorno -----
NODE_ENV=production

# Puerto de la app. En Hostinger lo asigna la plataforma — déjalo vacío
# o con 3000 para desarrollo local.
PORT=3000

# ----- URL del sitio (cambia cuando migres a hurricanesolution.com) -----
SITE_URL=https://orange-mandrill-877092.hostingersite.com

# Lista de orígenes permitidos por CORS, separados por coma.
# Inicialmente solo el dominio temporal de Hostinger.
ALLOWED_ORIGINS=https://orange-mandrill-877092.hostingersite.com

# ----- Webhook Make.com (recibe leads del cotizador y formulario) -----
# IMPORTANTE: Este valor es secreto. Nunca commitear el real.
MAKE_WEBHOOK_URL=https://hook.us2.make.com/XXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----- Analytics -----
# Google Analytics 4 — ID de medición
GA_ID=G-XXXXXXXXXX

# Meta Pixel — ID del pixel de Facebook
# Si está vacío, el pixel no se carga (no se renderiza el script).
FB_PIXEL_ID=

# ----- Rate limiting -----
# Máximo de envíos al webhook por IP por hora
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=3600000

# ----- Logging -----
# Nivel: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
