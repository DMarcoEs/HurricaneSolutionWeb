<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css" />
    <style>
      .error-page {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4rem 1rem;
      }
      .error-page__inner {
        text-align: center;
        max-width: 32rem;
      }
      .error-page__status {
        font-size: 5rem;
        font-weight: 700;
        color: #0d2137;
        margin: 0;
        line-height: 1;
      }
      .error-page__message {
        font-size: 1.25rem;
        color: #6b7a8d;
        margin: 1rem 0 2rem;
      }
      .error-page__home {
        display: inline-block;
        background: #1b6ca8;
        color: #fff;
        padding: 0.75rem 1.5rem;
        border-radius: 0.375rem;
        text-decoration: none;
        font-weight: 600;
      }
      .error-page__home:hover { background: #2e8fd8; }
    </style>
  </head>
  <body>
    <main class="error-page">
      <div class="error-page__inner">
        <p class="error-page__status"><%= status %></p>
        <p class="error-page__message"><%= message %></p>
        <a class="error-page__home" href="/">Volver al inicio</a>
      </div>
    </main>
  </body>
</html>
