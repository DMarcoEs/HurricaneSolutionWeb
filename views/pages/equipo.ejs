<%# El Equipo — Hurricane Solution — diseño premium v2 %>

<style>
  .section-wrap{padding:100px 48px}
  .section-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--gray-500);margin-bottom:16px;display:flex;align-items:center;gap:10px}
  .section-label::before{content:'';display:block;width:24px;height:1px;background:var(--gray-500)}
  .section-title{font-family:var(--font-display);font-size:clamp(36px,4vw,60px);line-height:1;letter-spacing:.02em;margin-bottom:16px}
  .section-title em{font-style:normal;color:var(--accent)}
  .section-body{font-size:15px;font-weight:400;color:var(--gray-800);line-height:1.75;max-width:720px}
  .ip-hero{background:var(--black);background-image:linear-gradient(to right,rgba(10,10,10,0.82) 40%,rgba(10,10,10,0.30) 100%),url('/img/equipo-hero.jpeg');background-size:cover;background-repeat:no-repeat;background-position:center 30%;padding:100px 48px 80px;position:relative;overflow:hidden;min-height:520px;display:flex;align-items:center}
  .ip-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 30% 50%,rgba(36,183,219,.06),transparent);pointer-events:none}
  .ip-hero-inner{max-width:700px;position:relative;z-index:1}
  .ip-hero .section-label{color:var(--gray-600)}
  .ip-hero .section-label::before{background:var(--gray-600)}
  .ip-hero-title{font-family:var(--font-display);font-size:clamp(42px,6vw,80px);line-height:1;letter-spacing:.02em;color:var(--white);margin-bottom:20px}
  .ip-hero-title em{font-style:normal;color:var(--accent)}
  .ip-hero-sub{font-size:16px;font-weight:400;color:var(--white);line-height:1.75;max-width:560px;margin-bottom:36px}
  .ip-hero-btns{display:flex;gap:12px;flex-wrap:wrap}
  .ip-hero-stat{display:flex;gap:40px;margin-top:40px;flex-wrap:wrap}
  .ip-hero-stat-num{font-family:var(--font-display);font-size:40px;letter-spacing:.03em;color:var(--accent);line-height:1}
  .ip-hero-stat-label{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--white);margin-top:4px}
  .director-layout{margin-top:40px}
  .director-badges{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px}
  .director-badge{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:5px 12px;border:1px solid var(--gray-300);color:var(--gray-600)}
  .director-badge--accent{border-color:var(--accent);color:var(--accent)}
  .director-name{font-family:var(--font-display);font-size:clamp(32px,3.5vw,52px);line-height:1;letter-spacing:.02em;color:var(--black);margin-bottom:6px}
  .director-role{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:24px}
  .director-bio{font-size:14px;font-weight:400;color:var(--gray-800);line-height:1.8;margin-bottom:20px}
  .director-quote{border-left:3px solid var(--accent);padding-left:20px;margin:28px 0}
  .director-quote p{font-size:15px;font-style:italic;color:var(--gray-900);line-height:1.7;font-weight:400}
  .director-certs{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;margin-top:32px}
  .director-cert{background:var(--offwhite);border:1px solid var(--gray-200);padding:20px 24px}
  .director-cert-title{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--black);margin-bottom:6px}
  .director-cert-body{font-size:12px;font-weight:400;color:var(--black);line-height:1.6}
  .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:56px}
  .team-card{background:var(--white);border:1px solid var(--gray-200);padding:40px 36px;transition:border-color .3s}
  .team-card:hover{border-color:var(--black)}
  .team-avatar{width:64px;height:64px;background:var(--black);color:var(--white);font-family:var(--font-display);font-size:22px;letter-spacing:.04em;display:flex;align-items:center;justify-content:center;margin-bottom:20px}
  .team-card.placeholder .team-avatar{background:var(--gray-100);color:var(--gray-400)}
  .team-name{font-family:var(--font-display);font-size:22px;letter-spacing:.03em;color:var(--black);line-height:1.1;margin-bottom:6px}
  .team-role{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:14px}
  .team-body{font-size:13px;font-weight:400;color:var(--black);line-height:1.7}
  .section-wrap-dark{padding:100px 48px;background:var(--black);color:var(--white)}
  .section-wrap-dark .section-label{color:var(--gray-600)}
  .section-wrap-dark .section-label::before{background:var(--gray-600)}
  .section-wrap-dark .section-title{color:var(--white)}
  .way-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;margin-top:56px}
  .way-card{background:rgba(255,255,255,.04);border:1px solid var(--gray-800);padding:48px 40px;transition:border-color .3s,background .3s}
  .way-card:hover{border-color:var(--accent);background:rgba(255,255,255,.06)}
  .way-num{font-family:var(--font-display);font-size:48px;letter-spacing:.04em;color:var(--accent);line-height:1;margin-bottom:24px}
  .way-title{font-family:var(--font-display);font-size:24px;letter-spacing:.03em;color:var(--white);margin-bottom:12px;line-height:1.1}
  .way-body{font-size:13px;font-weight:400;color:var(--white);line-height:1.7}
  #final-cta{background:var(--black);padding:120px 48px;text-align:center;position:relative;overflow:hidden}
  .final-cta-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 100%,rgba(36,183,219,.07),transparent);pointer-events:none}
  .final-cta-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:24px;position:relative}
  .final-cta-title{font-family:var(--font-display);font-size:clamp(48px,7vw,100px);line-height:.95;letter-spacing:.01em;color:var(--white);margin-bottom:24px;position:relative}
  .final-cta-sub{font-size:15px;font-weight:400;color:var(--white);line-height:1.7;max-width:560px;margin:0 auto 48px;position:relative}
  .final-cta-actions{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;position:relative}
  .btn-white{position:relative;overflow:hidden;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:rgba(36,183,219,.05);color:var(--white);border:1px solid rgba(36,183,219,.2);border-radius:9999px;padding:14px 36px;text-decoration:none;display:inline-block;transition:background .2s,border-color .3s}
  .btn-white::before{content:'';position:absolute;top:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(36,183,219,.8),transparent);opacity:0;transition:opacity .4s}
  .btn-white::after{content:'';position:absolute;bottom:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(36,183,219,.5),transparent);opacity:0;transition:opacity .4s}
  .btn-white:hover{background:rgba(36,183,219,.0);border-color:rgba(36,183,219,.35);color:var(--white)}
  .btn-white:hover::before,.btn-white:hover::after{opacity:1}
  .btn-outline-white{position:relative;overflow:hidden;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:rgba(37,211,102,.05);color:#fff;border:1px solid rgba(37,211,102,.25);border-radius:9999px;padding:14px 36px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:background .2s,border-color .3s}
  .btn-outline-white::before{content:'';position:absolute;top:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(37,211,102,.8),transparent);opacity:0;transition:opacity .4s}
  .btn-outline-white::after{content:'';position:absolute;bottom:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(37,211,102,.5),transparent);opacity:0;transition:opacity .4s}
  .btn-outline-white:hover{background:rgba(37,211,102,.0);border-color:rgba(37,211,102,.4);color:#fff}
  .btn-outline-white:hover::before,.btn-outline-white:hover::after{opacity:1}
  .reveal{opacity:0;transform:translateY(20px);transition:opacity .65s ease,transform .65s ease}
  .reveal.visible{opacity:1;transform:translateY(0)}
  @media(max-width:1024px){.director-layout{grid-template-columns:1fr}.director-img-wrap{max-width:380px}.team-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:768px){.ip-hero{padding:72px 20px 56px;min-height:auto}.ip-hero-btns{flex-direction:column}.ip-hero-btns a{text-align:center;width:100%}.ip-hero-stat{gap:24px}.section-wrap,.section-wrap-dark{padding:64px 20px}.team-grid,.way-grid,.director-certs{grid-template-columns:1fr}#final-cta{padding:80px 20px}.final-cta-actions{flex-direction:column;align-items:center}}
</style>

<!-- HERO -->
<section class="ip-hero">
  <div class="ip-hero-inner">
    <div class="section-label reveal">El Equipo</div>
    <h1 class="ip-hero-title reveal">EL EQUIPO<br><em>DETRÁS.</em></h1>
    <p class="ip-hero-sub reveal">Expertos en protección contra huracanes con más de 15 años operando en las costas de México. Cada instalación, supervisada desde el primer hasta el último ancla.</p>
    <div class="ip-hero-btns reveal">
      <a href="/cotizador" class="btn-white">Realizar una cotización</a>
      <a href="<%= site.whatsapp.url %>" class="btn-outline-white" target="_blank" rel="noopener">WhatsApp</a>
    </div>
    <div class="ip-hero-stat reveal">
      <div class="ip-hero-stat-item">
        <div class="ip-hero-stat-num">15+</div>
        <div class="ip-hero-stat-label">Años en operación</div>
      </div>
      <div class="ip-hero-stat-item">
        <div class="ip-hero-stat-num">30+</div>
        <div class="ip-hero-stat-label">Tormentas documentadas</div>
      </div>
      <div class="ip-hero-stat-item">
        <div class="ip-hero-stat-num">A+</div>
        <div class="ip-hero-stat-label">Calificación BBB</div>
      </div>
    </div>
  </div>
</section>

<!-- DIRECTOR GENERAL -->
<section class="section-wrap">
  <div class="section-label reveal">Liderazgo</div>
  <h2 class="section-title reveal">DIRECTOR <em>GENERAL.</em></h2>
  <div class="director-layout reveal">
    <div>
      <div class="director-badges">
        <span class="director-badge director-badge--accent">Certificación Militar EUA</span>
        <span class="director-badge director-badge--accent">Tecnología Patentada</span>
        <span class="director-badge">Calificación A+ BBB</span>
        <span class="director-badge">Reconocimiento Asegurador</span>
      </div>
      <div class="director-name">Fernando Loría</div>
      <div class="director-role">Director General · Hurricane Solution</div>
      <p class="director-bio">Fernando Loría es reconocido como una de las principales autoridades en México en protección contra huracanes Categoría 5, riesgo por vientos extremos y estrategias de mitigación en condiciones reales para edificios costeros e infraestructura crítica.</p>
      <p class="director-bio">Su trayectoria conecta el desempeño estructural con la evaluación del riesgo asegurador, enfocándose en cómo la mitigación certificada impacta la exposición a pérdidas y la continuidad operativa. Colabora activamente con propietarios hoteleros, desarrolladores e inversionistas para alinear la protección física con los criterios de asegurabilidad.</p>
      <div class="director-quote">
        <p>"Elevar la protección contra huracanes en México de una mejora opcional a un requisito esencial del desarrollo costero responsable."</p>
      </div>
      <div class="director-certs">
        <div class="director-cert">
          <div class="director-cert-title">Certificación Militar</div>
          <div class="director-cert-body">Único sistema con certificación militar de los Estados Unidos en México. Level E — el mismo estándar que instalaciones esenciales del ejército.</div>
        </div>
        <div class="director-cert">
          <div class="director-cert-title">Reconocimiento Asegurador</div>
          <div class="director-cert-body">Reconocido por Chubb, AIG y Mapfre como medida de mitigación certificada. Puede reducir significativamente la prima anual de su póliza.</div>
        </div>
        <div class="director-cert">
          <div class="director-cert-title">Tecnología Patentada</div>
          <div class="director-cert-body">Sistema de anclaje patentado que garantiza estándares de desempeño real. Fabricado en EUA, certificado Miami-Dade NOA y Florida Building Code.</div>
        </div>
        <div class="director-cert">
          <div class="director-cert-title">Evaluación Técnica</div>
          <div class="director-cert-body">Supervisa la evaluación técnica de sistemas certificados y la estrategia de implementación en proyectos institucionales y de gran escala.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EQUIPO DE CAMPO -->
<section class="section-wrap" style="background:var(--offwhite)">
  <div class="reveal">
    <div class="section-label">Nuestro equipo</div>
    <h2 class="section-title">LAS PERSONAS DETRÁS DE<br><em>CADA INSTALACIÓN.</em></h2>
    <p class="section-body" style="margin-top:16px">Cuando Hurricane Solution llega a su propiedad, llegan expertos, no vendedores. Cada miembro está capacitado para instalar, supervisar y operar bajo presión real.</p>
  </div>
  <div class="team-grid">
    <div class="team-card reveal">
      <div class="team-avatar">FL</div>
      <div class="team-name">Fernando Loría</div>
      <div class="team-role">Fundador y Director General</div>
      <p class="team-body">Más de 15 años en protección contra huracanes en México. Ha estado presente en más de 30 tormentas y desarrollado soluciones que no existían en el mercado. Autoridad en mitigación, seguros y riesgo extremo.</p>
    </div>
    <div class="team-card placeholder reveal" style="transition-delay:.1s">
      <div class="team-avatar">+</div>
      <div class="team-name">Equipo de Ingeniería</div>
      <div class="team-role">Diseño & Certificación</div>
      <p class="team-body">Nuestros ingenieros trabajan en cada proyecto asegurando que la solución funcione en condiciones reales. Cada instalación está respaldada por cálculos certificados y supervisión técnica.</p>
    </div>
    <div class="team-card placeholder reveal" style="transition-delay:.2s">
      <div class="team-avatar">+</div>
      <div class="team-name">Equipo de Campo</div>
      <div class="team-role">Instalación & Operación</div>
      <p class="team-body">Personal certificado con años de experiencia instalando bajo condiciones costeras extremas. Cada integrante puede desplegar el sistema completo en horas, sin grúas ni especialistas externos.</p>
    </div>
  </div>
</section>

<!-- FILOSOFÍA -->
<section class="section-wrap-dark">
  <div class="reveal">
    <div class="section-label">Nuestra filosofía</div>
    <h2 class="section-title">DOS PREGUNTAS.<br><em>SIEMPRE.</em></h2>
  </div>
  <div class="way-grid">
    <div class="way-card reveal">
      <div class="way-num">01</div>
      <div class="way-title">¿VA A FUNCIONAR CUANDO LLEGUE LA TORMENTA?</div>
      <p class="way-body">Cada decisión de instalación parte de esta pregunta. No cerramos un trabajo si la respuesta es no, aunque el cliente quiera algo diferente. Nuestra reputación vale más que un contrato. Quince años sin un sistema que haya fallado nos respaldan.</p>
    </div>
    <div class="way-card reveal" style="transition-delay:.1s">
      <div class="way-num">02</div>
      <div class="way-title">¿PUEDE SU EQUIPO INSTALARLO A TIEMPO?</div>
      <p class="way-body">Un sistema que no puede desplegarse antes de la tormenta no protege nada. Diseñamos cada instalación pensando en el personal que va a usarla, con o sin nosotros presentes. El manual de operación forma parte de cada entrega.</p>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section id="final-cta">
  <div class="final-cta-bg"></div>
  <div class="final-cta-label reveal">Que hable el trabajo</div>
  <h2 class="final-cta-title reveal">¿QUIERE CONOCER<br>AL EQUIPO?</h2>
  <p class="final-cta-sub reveal">Solicite una visita o videollamada. Sin costo, sin compromiso, que hable el trabajo.</p>
  <div class="final-cta-actions reveal">
    <a class="btn-white" href="/contacto">Realizar una cotización</a>
    <a class="btn-outline-white" href="<%= site.whatsapp.url %>" target="_blank" rel="noopener">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.849L0 24l6.335-1.652A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.814 9.814 0 01-5.016-1.378l-.36-.214-3.732.979.994-3.636-.235-.374A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
      WhatsApp
    </a>
  </div>
</section>

<script>
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(function(el) { obs.observe(el); });
</script>
