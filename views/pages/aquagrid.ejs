<!-- LIGHTBOX AquaGrid Gallery -->
<div id="ag-lightbox" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.94);z-index:9999;align-items:center;justify-content:center;padding:24px;cursor:pointer;">
  <button id="ag-lb-close" style="position:fixed;top:20px;right:24px;background:none;border:1px solid rgba(255,255,255,.4);color:#fff;font-size:18px;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:10000;">✕</button>
  <button id="ag-lb-prev" style="position:fixed;left:20px;top:50%;transform:translateY(-50%);background:none;border:1px solid rgba(255,255,255,.3);color:#fff;font-size:22px;width:48px;height:48px;cursor:pointer;z-index:10000;">‹</button>
  <img id="ag-lb-img" src="" alt="" style="max-width:92vw;max-height:92vh;object-fit:contain;cursor:default;box-shadow:0 0 80px rgba(0,0,0,.9);" />
  <button id="ag-lb-next" style="position:fixed;right:20px;top:50%;transform:translateY(-50%);background:none;border:1px solid rgba(255,255,255,.3);color:#fff;font-size:22px;width:48px;height:48px;cursor:pointer;z-index:10000;">›</button>
  <div id="ag-lb-counter" style="position:fixed;bottom:20px;left:50%;transform:translateX(-50%);font-size:11px;font-weight:700;letter-spacing:.1em;color:rgba(255,255,255,.4);font-family:'Lato',sans-serif;"></div>
</div>

<script>
(function(){
  var lb = document.getElementById('ag-lightbox');
  var img = document.getElementById('ag-lb-img');
  var counter = document.getElementById('ag-lb-counter');
  var tiles = [];
  var current = 0;

  function buildList(){
    document.querySelectorAll('.ag-lb img').forEach(function(el){ tiles.push(el.src); });
  }

  function open(idx){
    current = idx;
    img.src = tiles[current];
    counter.textContent = (current+1) + ' / ' + tiles.length;
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function close(){
    lb.style.display = 'none';
    document.body.style.overflow = '';
    img.src = '';
  }

  function prev(){ current = (current - 1 + tiles.length) % tiles.length; img.src = tiles[current]; counter.textContent = (current+1)+' / '+tiles.length; }
  function next(){ current = (current + 1) % tiles.length; img.src = tiles[current]; counter.textContent = (current+1)+' / '+tiles.length; }

  buildList();

  document.querySelectorAll('.ag-lb').forEach(function(tile, i){
    tile.style.cursor = 'zoom-in';
    tile.addEventListener('click', function(){ open(i); });
  });

  document.getElementById('ag-lb-close').addEventListener('click', function(e){ e.stopPropagation(); close(); });
  document.getElementById('ag-lb-prev').addEventListener('click', function(e){ e.stopPropagation(); prev(); });
  document.getElementById('ag-lb-next').addEventListener('click', function(e){ e.stopPropagation(); next(); });
  lb.addEventListener('click', close);
  document.addEventListener('keydown', function(e){
    if(lb.style.display==='flex'){
      if(e.key==='Escape') close();
      if(e.key==='ArrowLeft') prev();
      if(e.key==='ArrowRight') next();
    }
  });
})();
</script>

