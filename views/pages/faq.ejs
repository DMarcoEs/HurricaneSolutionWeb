<%# FAQ — Hurricane Solution — diseño premium v2 %>

<style>
  /* SECTIONS */
  .section-wrap{padding:100px 48px}
  .section-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--gray-500);margin-bottom:16px;display:flex;align-items:center;gap:10px}
  .section-label::before{content:'';display:block;width:24px;height:1px;background:var(--gray-500)}
  .section-title{font-family:var(--font-display);font-size:clamp(36px,4vw,60px);line-height:1;letter-spacing:.02em;margin-bottom:16px}
  .section-title em{font-style:normal;color:var(--accent)}

  /* INNER PAGE HERO */
  .ip-hero{
    background:var(--black);
    background-image:linear-gradient(to right,rgba(10,10,10,0.88) 45%,rgba(10,10,10,0.40) 100%),url('/img/hs-faq-hero.jpg');
    background-size:cover;
    background-repeat:no-repeat;
    background-position:center;
    padding:100px 48px 80px;
    position:relative;
    overflow:hidden;
  }
  .ip-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 30% 50%,rgba(36,183,219,.06),transparent);pointer-events:none}
  .ip-hero-inner{max-width:760px;position:relative;z-index:1}
  .ip-hero .section-label{color:var(--gray-600)}
  .ip-hero .section-label::before{background:var(--gray-600)}
  .ip-hero-title{font-family:var(--font-display);font-size:clamp(42px,6vw,80px);line-height:1;letter-spacing:.02em;color:var(--white);margin-bottom:20px}
  .ip-hero-title em{font-style:normal;color:var(--accent)}
  .ip-hero-sub{font-size:16px;font-weight:400;color:var(--white);line-height:1.75;max-width:580px;margin-bottom:36px}
  .ip-hero-btns{display:flex;gap:12px;flex-wrap:wrap}

  /* FAQ ACCORDION */
  .faq-list{max-width:880px;margin:0 auto;border-top:1px solid var(--gray-200)}
  .faq-item{border-bottom:1px solid var(--gray-200);transition:border-color .25s}
  .faq-item.is-open{border-bottom-color:var(--black)}
  .faq-q{width:100%;background:none;border:none;cursor:pointer;display:flex;align-items:flex-start;justify-content:space-between;gap:24px;padding:28px 4px;text-align:left;font-family:var(--font-display);font-size:clamp(20px,2.2vw,26px);letter-spacing:.02em;line-height:1.15;color:var(--black);transition:color .2s}
  .faq-q:hover{color:var(--accent)}
  .faq-arr{flex-shrink:0;width:32px;height:32px;border:1px solid var(--gray-300);display:flex;align-items:center;justify-content:center;color:var(--gray-500);transition:transform .3s,border-color .25s,color .25s;margin-top:2px}
  .faq-item.is-open .faq-arr{transform:rotate(180deg);border-color:var(--black);color:var(--black)}
  .faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease}
  .faq-item.is-open .faq-a{max-height:500px}
  .faq-a-inner{padding:0 4px 32px;font-size:14px;font-weight:400;color:var(--gray-800);line-height:1.8;max-width:760px}
  .faq-cta{text-align:center;margin-top:64px}
  .btn-dark{font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:var(--black);color:var(--white);padding:16px 32px;text-decoration:none;display:inline-block;transition:background .2s}
  .btn-dark:hover{background:var(--gray-700)}

  /* FINAL CTA */
  #final-cta{background:var(--black);padding:120px 48px;text-align:center;position:relative;overflow:hidden}
  .final-cta-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 100%,rgba(36,183,219,.07),transparent);pointer-events:none}
  .final-cta-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:24px;position:relative}
  .final-cta-title{font-family:var(--font-display);font-size:clamp(48px,7vw,100px);line-height:.95;letter-spacing:.01em;color:var(--white);margin-bottom:24px;position:relative}
  .final-cta-sub{font-size:15px;font-weight:400;color:var(--white);line-height:1.7;max-width:560px;margin:0 auto 48px;position:relative}
  .final-cta-actions{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;position:relative}
  .btn-white{position:relative;overflow:hidden;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:rgba(36,183,219,.05);color:var(--white);border:1px solid rgba(36,183,219,.2);border-radius:9999px;padding:14px 36px;text-decoration:none;display:inline-block;transition:background .2s,border-color .3s}
  .btn-white::before{content:'';position:absolute;top:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(36,183,219,.8),transparent);opacity:0;transition:opacity .4s}
  .btn-white::after{content:'';position:absolute;bottom:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(36,183,219,.5),transparent);opacity:0;transition:opacity .4s}
  .btn-white:hover{background:rgba(36,183,219,.0);border-color:rgba(36,183,219,.35);color:var(--white)}
  .btn-white:hover::before,.btn-white:hover::after{opacity:1}
  .btn-outline-white{position:relative;overflow:hidden;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:rgba(37,211,102,.05);color:#fff;border:1px solid rgba(37,211,102,.25);border-radius:9999px;padding:14px 36px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:background .2s,border-color .3s}
  .btn-outline-white::before{content:'';position:absolute;top:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(37,211,102,.8),transparent);opacity:0;transition:opacity .4s}
  .btn-outline-white::after{content:'';position:absolute;bottom:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(37,211,102,.5),transparent);opacity:0;transition:opacity .4s}
  .btn-outline-white:hover{background:rgba(37,211,102,.0);border-color:rgba(37,211,102,.4);color:#fff}
  .btn-outline-white:hover::before,.btn-outline-white:hover::after{opacity:1}

  /* REVEAL */
  .reveal{opacity:0;transform:translateY(20px);transition:opacity .65s ease,transform .65s ease}
  .reveal.visible{opacity:1;transform:translateY(0)}

  /* RESPONSIVE */
  @media(max-width:768px){
    .ip-hero{
      background-image:linear-gradient(to bottom,rgba(10,10,10,0.85) 0%,rgba(10,10,10,0.75) 100%),url('/img/hs-faq-hero-mobile.jpg');
      background-position:center top;
      padding:72px 20px 56px;
    }
    .ip-hero-btns{flex-direction:column}
    .ip-hero-btns a{text-align:center;width:100%}
    .section-wrap{padding:64px 20px}
    .faq-q{font-size:18px;padding:22px 4px}
    #final-cta{padding:80px 20px}
    .final-cta-actions{flex-direction:column;align-items:center}
  }
</style>

<!-- INNER PAGE HERO -->
<style>
  .faq-hero-layout{display:grid;grid-template-columns:1fr 650px;align-items:center;gap:50px;min-height:inherit;width:100%}
  .faq-hero-logo-wrap{display:flex;align-items:flex-start;justify-content:flex-start;margin-top:-50px}
  .faq-hero-logo-wrap img{width:650px;max-width:90%;opacity:.92;filter:drop-shadow(0 0 40px rgba(36,183,219,.18))}
  @media(max-width:900px){.faq-hero-layout{grid-template-columns:1fr}.faq-hero-logo-wrap{display:none}}
</style>
<section class="ip-hero">
  <div class="faq-hero-layout">
    <div class="ip-hero-inner" style="max-width:none">
      <div class="section-label reveal">FAQ</div>
      <h1 class="ip-hero-title reveal">PREGUNTAS <em>FRECUENTES.</em></h1>
      <p class="ip-hero-sub reveal">Todo lo que necesita saber sobre protección contra huracanes en México.</p>
      <div class="ip-hero-btns reveal">
        <a href="<%= site.whatsapp.url %>" class="btn-outline-white" target="_blank" rel="noopener">WhatsApp</a>
      </div>
    </div>
    <div class="faq-hero-logo-wrap reveal">
      <img src="/img/hs-logo.png" alt="Hurricane Solution" />
    </div>
  </div>
</section>

<!-- FAQ ACCORDION -->
<section class="section-wrap" style="background:var(--offwhite)">
  <div class="faq-list reveal">

    <div class="faq-item">
      <button class="faq-q" type="button"><span>¿QUÉ DIFERENCIA A HURRICANE SOLUTION DE OTRAS EMPRESAS EN MÉXICO?</span><span class="faq-arr">▼</span></button>
      <div class="faq-a"><div class="faq-a-inner">Somos la única empresa en México con certificación militar Level E — la única que prueba las 4 fuerzas de un huracán al mismo tiempo. También somos el único miembro de la International Hurricane Protection Association fuera de los Estados Unidos, y nuestro sistema de anclaje es el único patentado en México. Llevamos operando desde 2008 con cero fallas en instalaciones correctamente ejecutadas.</div></div>
    </div>

    <div class="faq-item">
      <button class="faq-q" type="button"><span>¿QUÉ ES LA CERTIFICACIÓN LEVEL E Y POR QUÉ IMPORTA?</span><span class="faq-arr">▼</span></button>
      <div class="faq-a"><div class="faq-a-inner">Level E es una certificación desarrollada por el ejército de los Estados Unidos para proteger instalaciones esenciales. Es la única certificación que prueba viento, lluvia, proyectiles y cambio de presión barométrica al mismo tiempo. Las otras certificaciones los prueban por separado. Somos los únicos en México con esta certificación.</div></div>
    </div>

    <div class="faq-item">
      <button class="faq-q" type="button"><span>¿CUÁL ES LA DIFERENCIA ENTRE HS-1500, HS-1250 Y HS-875?</span><span class="faq-arr">▼</span></button>
      <div class="faq-a"><div class="faq-a-inner">El HS-1500 es nuestra línea insignia — tela balística con certificación Level E, más de 1,500 psi y garantía de 10 años. El HS-1250 es Cat 5 certificado, disponible en blanco, garantía 7 años — ideal cuando la estética es prioridad. El HS-875 es más accesible, certificado hasta Cat 3, garantía 5 años — adecuado para residencias alejadas de la costa.</div></div>
    </div>

    <div class="faq-item">
      <button class="faq-q" type="button"><span>¿QUÉ ES AQUAGRID Y CUÁNDO LO NECESITO?</span><span class="faq-arr">▼</span></button>
      <div class="faq-a"><div class="faq-a-inner">AquaGrid es un sistema de malla de alta resistencia para aperturas que los sistemas convencionales no pueden cubrir. Los sistemas estándar tienen un límite de 3.8 metros — AquaGrid puede cubrir más de 20 metros. Ideal para lobbies de hotel, showrooms de autos, hospitales y cualquier espacio con grandes aperturas.</div></div>
    </div>

    <div class="faq-item">
      <button class="faq-q" type="button"><span>¿EN CUÁNTO TIEMPO SE PUEDE DESPLEGAR ANTES DE UNA TORMENTA?</span><span class="faq-arr">▼</span></button>
      <div class="faq-a"><div class="faq-a-inner">Para un hotel grande, un empleado por habitación puede proteger su espacio en 3 a 5 minutos. Para una residencia, el despliegue total suele tomar 1 a 3 horas con 2 personas. Capacitamos a su personal y dejamos un manual escrito.</div></div>
    </div>

    <div class="faq-item">
      <button class="faq-q" type="button"><span>¿LOS SISTEMAS AYUDAN A REDUCIR EL COSTO DEL SEGURO?</span><span class="faq-arr">▼</span></button>
      <div class="faq-a"><div class="faq-a-inner">Sí. Aseguradoras como Chubb, AIG y Mapfre reconocen los sistemas HS-1500 como medida de mitigación certificada. Le proporcionamos la documentación necesaria para presentar a su aseguradora.</div></div>
    </div>

    <div class="faq-item">
      <button class="faq-q" type="button"><span>¿CUÁNTO DURA EL SISTEMA Y QUÉ MANTENIMIENTO REQUIERE?</span><span class="faq-arr">▼</span></button>
      <div class="faq-a"><div class="faq-a-inner">La vida útil es de 15 a 20 años. El mantenimiento es mínimo: lavado ocasional con agua y jabón. Resistentes a UV, moho y salinidad — diseñados para el clima costero.</div></div>
    </div>

    <div class="faq-item">
      <button class="faq-q" type="button"><span>¿DÓNDE OFRECEN SERVICIO Y CÓMO SOLICITO UNA EVALUACIÓN?</span><span class="faq-arr">▼</span></button>
      <div class="faq-a"><div class="faq-a-inner">Estamos basados en Playa del Carmen y nos desplazamos a Los Cabos, Vallarta, Mazatlán y Acapulco. Puede solicitar su evaluación llamando al <%= site.phone.display %>, por WhatsApp al <%= site.whatsapp.display %>, o por el formulario en esta página. Sin costo y sin compromiso.</div></div>
    </div>

  </div>
  <div class="faq-cta reveal">
    <a href="/contacto" class="btn-dark">¿Más preguntas? Contáctenos</a>
  </div>
</section>

<!-- FINAL CTA -->
<section id="final-cta">
  <div class="final-cta-bg"></div>
  <div class="final-cta-label reveal">¿No encontró su respuesta?</div>
  <h2 class="final-cta-title reveal">HABLEMOS<br>DE SU PROYECTO.</h2>
  <p class="final-cta-sub reveal">Sin costo y sin compromiso. Le respondemos el mismo día hábil.</p>
  <div class="final-cta-actions reveal">
    <a class="btn-white" href="/cotizador">Realizar una cotización</a>
    <a class="btn-outline-white" href="<%= site.whatsapp.url %>" target="_blank" rel="noopener">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.849L0 24l6.335-1.652A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.814 9.814 0 01-5.016-1.378l-.36-.214-3.732.979.994-3.636-.235-.374A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
      WhatsApp
    </a>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-item').forEach(function(item) {
    item.querySelector('.faq-q').addEventListener('click', function() {
      item.classList.toggle('is-open');
    });
  });
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(function(el) { obs.observe(el); });
</script>
