  <button class="lb-close" id="lb-close-btn" aria-label="Cerrar">&#x2715;</button>
  <img id="hs-lightbox-img" src="" alt="Vista ampliada" />
</div>

<style>
  .prod-visual { position:relative!important;width:100%!important;height:auto!important;min-height:unset!important;max-height:unset!important;overflow:visible!important;background:transparent!important;margin-bottom:20px!important;display:block!important; }
