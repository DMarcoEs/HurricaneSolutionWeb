    <div class="gal-frame active">
      <img src="/img/gallery/hot-1.jpg" alt="" loading="lazy" />
      <img src="/img/gallery/hot-2.jpg" alt="" loading="lazy" />
    </div>
    <div class="gal-frame">
      <img src="/img/gallery/hot-3.jpg" alt="" loading="lazy" />
      <img src="/img/gallery/hot-4.jpg" alt="" loading="lazy" />
    </div>
    <div class="gal-frame">
      <img src="/img/gallery/hot-5.jpg" alt="" loading="lazy" />
      <img src="/img/gallery/hot-6.jpg" alt="" loading="lazy" />
    </div>
    <div class="gal-frame" style="grid-template-columns:1fr;">
      <img src="/img/gallery/hot-7.jpg" alt="" loading="lazy" style="max-width:700px;margin:0 auto;" />
    </div>
  </div>
  <div class="gal-footer">
    <div class="gal-left">
      <div class="gal-counter"><span id="gal-cur">1</span> / 4</div>
      <div class="gal-dots">
        <div class="gal-dot active" data-idx="0"></div>
        <div class="gal-dot" data-idx="1"></div>
        <div class="gal-dot" data-idx="2"></div>
        <div class="gal-dot" data-idx="3"></div>
      </div>
    </div>
    <div class="gal-arrows">
      <button class="gal-arrow" id="gal-prev">&#8592;</button>
      <button class="gal-arrow" id="gal-next">&#8594;</button>
    </div>
  </div>
</section>

<script>
(function() {
  var frames  = document.querySelectorAll('#hs-gallery .gal-frame');
  var dots    = document.querySelectorAll('#hs-gallery .gal-dot');
  var counter = document.getElementById('gal-cur');
  var btnPrev = document.getElementById('gal-prev');
  var btnNext = document.getElementById('gal-next');
  var section = document.getElementById('hs-gallery');
  if (!frames.length) return;
  var current=0, total=frames.length, INTERVAL=5000, timer, paused=false;
  function goTo(idx) {
    frames[current].classList.remove('active'); dots[current].classList.remove('active');
    current=(idx+total)%total;
    frames[current].classList.add('active'); dots[current].classList.add('active');
    if(counter) counter.textContent=current+1;
  }
  function startAuto() { clearInterval(timer); if(paused) return; timer=setInterval(function(){goTo(current+1);},INTERVAL); }
  var stage=document.querySelector('#hs-gallery .gal-stage');
  if(stage) stage.addEventListener('click',function(e){
    if(e.target.tagName==='IMG') return;
    paused=!paused; if(paused) clearInterval(timer); else startAuto();
  });
  window.addEventListener('scroll',function(){
    if(!section||!paused) return;
    var r=section.getBoundingClientRect();
    if(r.bottom<0||r.top>window.innerHeight){paused=false;startAuto();}
  });
  dots.forEach(function(d){d.addEventListener('click',function(e){e.stopPropagation();goTo(parseInt(d.dataset.idx));paused=false;startAuto();});});
  if(btnPrev) btnPrev.addEventListener('click',function(e){e.stopPropagation();goTo(current-1);paused=false;startAuto();});
  if(btnNext) btnNext.addEventListener('click',function(e){e.stopPropagation();goTo(current+1);paused=false;startAuto();});
  document.querySelectorAll('#hs-gallery .gal-frame img').forEach(function(img){
    img.addEventListener('click',function(){
      var lb=document.getElementById('hs-lightbox'),lbImg=document.getElementById('hs-lightbox-img');
      if(lb&&lbImg){lbImg.src=img.src;lb.classList.add('is-open');document.body.style.overflow='hidden';}
    });
  });
  startAuto();
})();
</script>

