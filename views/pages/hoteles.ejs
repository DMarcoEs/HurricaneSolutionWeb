    min-height: 280px; cursor: pointer;
  }
  .feat-card img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform .5s ease; filter: brightness(.55);
  }
  .feat-card:hover img { transform: scale(1.05); filter: brightness(.75); }
  .feat-card-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 20px 16px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px; letter-spacing: .04em; color: #fff;
    background: linear-gradient(to top, rgba(0,0,0,.7), transparent);
  }
  .feat-card-label em {
    font-style: normal; color: #24b7db; display: block;
    font-size: 11px; font-family: 'Lato', sans-serif;
    font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 4px; opacity: .8;
  }
  .feat-clearfix { clear: both; }

  /* ── GALERÍA ─────────────────────────────────── */
  #hs-gallery { background: #0a0a0a; padding: 80px 0; }
  .gal-header { padding: 0 64px 40px; }
  .gal-eyebrow {
    font-size: 10px; font-weight: 700; letter-spacing: .22em;
    text-transform: uppercase; color: #24b7db;
    display: flex; align-items: center; gap: 12px; margin-bottom: 14px;
