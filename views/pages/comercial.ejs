<!-- SYSTEM SHOWCASE -->
<section id="hs-showcase" class="section-wrap" style="background:var(--black);color:var(--white)">
  <div class="showcase-intro reveal">
    <div class="section-label" style="color:var(--gray-600)">Seleccione su sistema</div>
    <h2 class="section-title" style="color:var(--white)">CONOZCA CADA<br><em>SISTEMA EN DETALLE.</em></h2>
  </div>

  <div class="showcase-layout">

    <!-- Imagen izquierda -->
    <div class="showcase-img-wrap">
      <img id="sc-img" src="/img/hs-1500.png" alt="Sistema HS-1500" />
      <div class="sc-progress-bar"><div id="sc-progress"></div></div>
    </div>

    <!-- Info central -->
    <div class="showcase-info-wrap">
      <div class="sc-tabs">
        <button class="sc-tab active" data-sc="0">HS-1500</button>
        <button class="sc-tab" data-sc="1">HS-1250</button>
        <button class="sc-tab" data-sc="2">HS-875</button>
        <button class="sc-tab" data-sc="3">HS-GRID</button>
        <button class="sc-tab" data-sc="4">CLIP</button>
        <button class="sc-tab" data-sc="5">RAIN</button>
        <button id="sc-resume">Reanudar</button>
      </div>
      <div id="sc-paused-hint"></div>
      <div class="sc-body">
        <div class="sc-badge" id="sc-badge">Level E · Militar</div>
        <div class="sc-model" id="sc-model">HS-1500</div>
        <div class="sc-cert" id="sc-cert">Certificación Militar Level E · Categoría 5</div>
        <p class="sc-desc" id="sc-desc">Tela balística — el mismo material del airbag de su automóvil. Más de 1,500 psi, diseñado para propiedades frente al mar y hoteles de primera línea.</p>
        <ul class="sc-features" id="sc-features">
          <li>Más de 1,500 psi (Cat 5 = 1,200 psi)</li>
          <li>Certificación Level E — Instalaciones Esenciales</li>
          <li>Miami-Dade NOA y Florida Building Code</li>
          <li>Anclaje flexible patentado — 8 puntos</li>
          <li>Garantía 10 años</li>
        </ul>
        <a class="sc-cta" id="sc-cta" href="/cotizador">Cotizar HS-1500</a>
      </div>
    </div>

    <!-- Certificaciones fijas derecha -->
    <div class="showcase-certs">
      <div class="sc-certs-label">Certificaciones</div>
      <img src="/img/cer-general.png" alt="Certificaciones Hurricane Solution" class="sc-cert-img sc-cert-single" />
    </div>

  </div>
</section>

<style>
  /* ── SHOWCASE ── */
  #hs-showcase { padding: 48px 48px 60px; }
  .showcase-intro { margin-bottom: 36px; text-align: center; }

  /* 3 columnas: imagen | info | certs */
  .showcase-layout {
    display: grid;
    grid-template-columns: 35% 1fr 160px;
    gap: 40px;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Imagen centrada verticalmente */
  .showcase-img-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .showcase-img-wrap img {
    width: auto;
    max-width: 100%;
    max-height: calc(100vh - 220px);
    height: auto;
    object-fit: contain;
    display: block;
    transition: opacity .4s ease;
  }
  .showcase-img-wrap img.fading { opacity: 0; }

  .sc-progress-bar { display:none; }
  #sc-progress { height:100%;background:var(--accent);width:0%; }

  /* Tabs */
  .sc-tabs { display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;align-items:center; }
  .sc-tab { font-family:var(--font-display);font-size:14px;letter-spacing:.08em;padding:10px 20px;background:none;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.4);cursor:pointer;transition:all .2s; }
  .sc-tab:hover { border-color:rgba(255,255,255,.4);color:rgba(255,255,255,.7); }
  .sc-tab.active { border-color:var(--accent);color:var(--accent);background:rgba(36,183,219,.08); }
  #sc-paused-hint { font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.25);margin-bottom:16px;min-height:14px; }
  #sc-resume { display:none;font-size:10px;letter-spacing:.1em;text-transform:uppercase;background:none;border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.4);padding:4px 10px;cursor:pointer;transition:all .2s;font-family:'Lato',sans-serif; }
  #sc-resume:hover { border-color:var(--accent);color:var(--accent); }
  #sc-resume.visible { display:inline-block; }

  /* Info */
  .sc-badge { display:inline-block;font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;background:var(--accent);color:var(--black);padding:4px 10px;margin-bottom:12px; }
  .sc-model { font-family:var(--font-display);font-size:clamp(40px,5vw,72px);line-height:1;color:var(--white);margin-bottom:4px; }
  .sc-cert { font-size:11px;color:var(--accent);font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:16px; }
  .sc-desc { font-size:13px;line-height:1.7;color:rgba(255,255,255,.88);margin-bottom:20px; }
  .sc-features { list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:28px; }
  .sc-features li { font-size:12px;color:rgba(255,255,255,.90);padding-left:18px;position:relative; }
  .sc-features li::before { content:'✓';position:absolute;left:0;color:var(--accent);font-size:11px; }
  .sc-cta { display:inline-block;font-family:var(--font-display);font-size:13px;letter-spacing:.12em;text-transform:uppercase;padding:12px 28px;background:var(--accent);color:var(--black);text-decoration:none;transition:background .2s; }
  .sc-cta:hover { background:#1a93b0;color:#fff; }

  /* ── CERTIFICACIONES (columna derecha fija) ── */
  .showcase-certs {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    border-left: 1px solid rgba(255,255,255,.08);
    padding-left: 24px;
  }
  .sc-certs-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(255,255,255,.25);
    margin-bottom: 4px;
    align-self: flex-start;
  }
  .sc-cert-img {
    width: 100%;
    height: auto;
    display: block;
    opacity: .85;
    filter: grayscale(20%);
    transition: opacity .2s;
  }
  .sc-cert-single { width: 125%; margin: 0 auto; }
  .sc-cert-img:hover { opacity: 1; filter: none; }

  /* ── Responsive ── */
  @media(max-width:1100px){
    .showcase-layout{ grid-template-columns: 38% 1fr 140px; gap:28px; }
  }
  @media(max-width:768px){
    #hs-showcase{ padding:48px 20px; }
    .showcase-layout{ grid-template-columns:1fr;gap:24px; }
    .showcase-certs{ flex-direction:row;flex-wrap:wrap;justify-content:center;border-left:none;border-top:1px solid rgba(255,255,255,.08);padding-left:0;padding-top:20px; }
    .sc-cert-img{ width:28%; }
    .sc-cert-single{ width:70%; }
    .showcase-img-wrap img{ max-height:55vw; }
    .sc-tab{ font-size:12px;padding:8px 14px; }
  }
  @media(max-width:480px){ .sc-tabs{flex-direction:column;} }
</style>

<script>
(function(){
  var DURATION=5000;
  var systems=[
    {img:'/img/hs-1500.png',badge:'Level E · Militar',model:'HS-1500',cert:'Certificación Militar Level E · Categoría 5',desc:'Tela balística — el mismo material del airbag de su automóvil. Más de 1,500 psi, diseñado para propiedades frente al mar y hoteles de primera línea.',features:['Más de 1,500 psi (Cat 5 = 1,200 psi)','Certificación Level E — Instalaciones Esenciales','Miami-Dade NOA y Florida Building Code','Anclaje flexible patentado — 8 puntos','Garantía 10 años'],cta:'Cotizar HS-1500'},
    {img:'/img/hs-1250.png',badge:'Cat 5 · Translúcido',model:'HS-1250',cert:'Certificación Cat 5 · Translúcido',desc:'Poliéster con aramida. Disponible en blanco sin degradación UV, translúcido durante la tormenta. Ideal para hoteles modernos que cuidan la estética.',features:['Resistencia Cat 5 certificada','Disponible en blanco — sin degradación UV','Translúcido — visibilidad durante la tormenta','Miami-Dade Aprobado','Garantía 7 años'],cta:'Cotizar HS-1250'},
    {img:'/img/hs-875.png',badge:'Cat 3 · Polipropileno',model:'HS-875',cert:'Certificación Cat 3 · Polipropileno',desc:'Solución de alto rendimiento para propiedades a 3+ km de la costa. Polipropileno de alta densidad con garantía de 5 años y presupuesto controlado.',features:['Resistencia hasta 875 psi','Certificación Categoría 3','Translúcido — visibilidad durante la tormenta','Florida Building Code Aprobado','Garantía 5 años'],cta:'Cotizar HS-875'},
    {img:'/img/hs-grid.jpg',badge:'Grandes Superficies · Cat 5',model:'HS-GRID',cert:'Grandes Superficies · Fachadas',desc:'Sistema diseñado exclusivamente para grandes aperturas y fachadas completas. Donde cualquier otro sistema no puede instalarse, HS-GRID funciona.',features:['Grandes superficies y fachadas','Categoría 5 certificado','Alta resistencia tensil','Instalación sin grúas ni andamios','Próximamente disponible'],cta:'Consultar HS-GRID'},
    {img:'/img/hs-clip.png',badge:'Tecnología de Anclaje Patentada · Cat 5',model:'CLIP',cert:'Tecnología de Anclaje Patentada',desc:'Sistema de anclaje patentado que permite instalar y desinstalar las pantallas sin herramientas especiales. La solución más rápida del mercado.',features:['Anclaje sin herramientas','Despliegue en minutos','Compatible con todos los sistemas HS','Categoría 5 certificado','Próximamente disponible'],cta:'Consultar CLIP'},
    {img:'/img/hs-rain.jpeg',badge:'Protección Exterior · Manual',model:'RAIN PROTECTION',cert:'Toldos Verticales Enrollables · Uso Exterior',desc:'Toldo vertical enrollable para terrazas, restaurantes, balcones y zonas abiertas. Protege contra lluvia, arena y sol sin estructura permanente. Instalación en muro, pared, losa o techo.',features:['Tela diseñada para lluvia, arena y sol','Ideal para terrazas, restaurantes y pérgolas','Acción manual con manivela — sin electricidad','Longitud máxima 5.50 m por mecanismo','Instalación en muro, pared, losa o techo'],cta:'Consultar Rain Protection'}
  ];
  var current=0, timer=null, progTimer=null, startTime=null, paused=false;
  var img=document.getElementById('sc-img'),
      badge=document.getElementById('sc-badge'),
      model=document.getElementById('sc-model'),
      cert=document.getElementById('sc-cert'),
      desc=document.getElementById('sc-desc'),
      features=document.getElementById('sc-features'),
      cta=document.getElementById('sc-cta'),
      progress=document.getElementById('sc-progress'),
      hint=document.getElementById('sc-paused-hint'),
      resumeBtn=document.getElementById('sc-resume'),
      tabs=document.querySelectorAll('.sc-tab');

  function updateUI(idx,animate){
    var s=systems[idx];
    if(animate){img.classList.add('fading');setTimeout(function(){img.src=s.img;img.classList.remove('fading');},350);}
    else{img.src=s.img;}
    badge.textContent=s.badge; model.textContent=s.model; cert.textContent=s.cert;
    desc.textContent=s.desc;   cta.textContent=s.cta;
    features.innerHTML=s.features.map(function(f){return'<li>'+f+'</li>';}).join('');
    tabs.forEach(function(t,i){t.classList.toggle('active',i===idx);});
  }

  function startProgress(){
    progress.style.width='0%'; startTime=Date.now();
    if(progTimer)clearInterval(progTimer);
    progTimer=setInterval(function(){
      if(!paused) progress.style.width=Math.min(100,(Date.now()-startTime)/DURATION*100)+'%';
    },50);
  }

  function startAuto(){
    if(timer)clearInterval(timer);
    timer=setInterval(function(){
      if(!paused){current=(current+1)%systems.length;updateUI(current,true);startProgress();}
    },DURATION);
    startProgress();
  }

  function pause(){
    paused=true;
    if(hint)hint.textContent='Rotación pausada — tomese su tiempo';
    if(resumeBtn)resumeBtn.classList.add('visible');
  }

  function resume(){
    paused=false;
    if(hint)hint.textContent='';
    if(resumeBtn)resumeBtn.classList.remove('visible');
    startAuto();
  }

  updateUI(0,false); startAuto();

  tabs.forEach(function(tab){
    tab.addEventListener('click',function(){
      var idx=parseInt(tab.getAttribute('data-sc'));
      if(idx===current && paused) return;
      current=idx; updateUI(current,true);
      pause(); // pausa al hacer click manual
    });
  });

  if(resumeBtn) resumeBtn.addEventListener('click', resume);
})();
</script>


