<%# Comercial — Hurricane Solution — diseño premium v2 %>

<style>
  /* SECTIONS */
  .section-wrap{padding:100px 48px}
  .section-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--gray-500);margin-bottom:16px;display:flex;align-items:center;gap:10px}
  .section-label::before{content:'';display:block;width:24px;height:1px;background:var(--gray-500)}
  .section-body{font-size:15px;font-weight:400;color:var(--gray-800);line-height:1.75;max-width:520px}

  /* INNER PAGE HERO */
  .ip-hero{
    background:var(--black);
    background-image:linear-gradient(to right,rgba(10,10,10,0.88) 45%,rgba(10,10,10,0.40) 100%),url('/img/gallery/com-hero.jpg');
    background-size:cover;
    background-repeat:no-repeat;
    background-position:center;
    padding:100px 48px 80px;
    position:relative;
    overflow:hidden;
  }
  .ip-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 30% 50%,rgba(36,183,219,.06),transparent);pointer-events:none}
  .ip-hero-inner{max-width:760px;position:relative;z-index:1}
  .ip-hero .section-label{color:var(--gray-600)}
  .ip-hero .section-label::before{background:var(--gray-600)}
  .ip-hero-title{font-family:var(--font-display);font-size:clamp(42px,6vw,80px);line-height:1;letter-spacing:.02em;color:var(--white);margin-bottom:20px}
  .ip-hero-title em{font-style:normal;color:var(--accent)}
  .ip-hero-sub{font-size:16px;font-weight:400;color:var(--white);line-height:1.75;max-width:580px;margin-bottom:36px}
  .ip-hero-btns{display:flex;gap:12px;flex-wrap:wrap}

  /* BENEFITS */
  .ben-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:56px}
  .ben-card{background:var(--offwhite);border:1px solid var(--gray-200);padding:48px 40px;transition:border-color .3s,background .3s}
  .ben-card:hover{border-color:var(--black);background:var(--white)}
  .ben-icon{font-size:28px;margin-bottom:20px;display:block}
  .ben-title{font-family:var(--font-display);font-size:22px;letter-spacing:.04em;color:var(--black);margin-bottom:12px}
  .ben-body{font-size:13px;font-weight:400;color:var(--gray-800);line-height:1.75}

  /* SEGMENTS */
  .segments-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:56px}
  .seg-card{background:var(--white);border:1px solid var(--gray-200);padding:48px 40px;transition:border-color .3s}
  .seg-card:hover{border-color:var(--black)}
  .seg-icon{width:48px;height:48px;background:var(--black);margin-bottom:28px;display:flex;align-items:center;justify-content:center;font-size:22px}
  .seg-title{font-family:var(--font-display);font-size:26px;letter-spacing:.03em;color:var(--black);margin-bottom:12px;line-height:1.1}
  .seg-body{font-size:13px;font-weight:400;color:var(--gray-800);line-height:1.7}
  .seg-ex{font-size:11px;color:var(--accent);font-weight:700;margin-top:16px;letter-spacing:.04em}

  /* FINAL CTA */
  #final-cta{background:var(--black);padding:120px 48px;text-align:center;position:relative;overflow:hidden}
  .final-cta-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 100%,rgba(36,183,219,.07),transparent);pointer-events:none}
  .final-cta-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:24px;position:relative}
  .final-cta-title{font-family:var(--font-display);font-size:clamp(48px,7vw,100px);line-height:.95;letter-spacing:.01em;color:var(--white);margin-bottom:24px;position:relative}
  .final-cta-sub{font-size:15px;font-weight:400;color:var(--white);line-height:1.7;max-width:560px;margin:0 auto 48px;position:relative}
  .final-cta-actions{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;position:relative}
  .btn-white{position:relative;overflow:hidden;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:rgba(36,183,219,.05);color:var(--white);border:1px solid rgba(36,183,219,.2);border-radius:9999px;padding:14px 36px;text-decoration:none;display:inline-block;transition:background .2s,border-color .3s}
  .btn-white::before{content:'';position:absolute;top:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(36,183,219,.8),transparent);opacity:0;transition:opacity .4s}
  .btn-white::after{content:'';position:absolute;bottom:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(36,183,219,.5),transparent);opacity:0;transition:opacity .4s}
  .btn-white:hover{background:rgba(36,183,219,.0);border-color:rgba(36,183,219,.35);color:var(--white)}
  .btn-white:hover::before,.btn-white:hover::after{opacity:1}
  .btn-outline-white{position:relative;overflow:hidden;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:rgba(37,211,102,.05);color:#fff;border:1px solid rgba(37,211,102,.25);border-radius:9999px;padding:14px 36px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:background .2s,border-color .3s}
  .btn-outline-white::before{content:'';position:absolute;top:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(37,211,102,.8),transparent);opacity:0;transition:opacity .4s}
  .btn-outline-white::after{content:'';position:absolute;bottom:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(37,211,102,.5),transparent);opacity:0;transition:opacity .4s}
  .btn-outline-white:hover{background:rgba(37,211,102,.0);border-color:rgba(37,211,102,.4);color:#fff}
  .btn-outline-white:hover::before,.btn-outline-white:hover::after{opacity:1}

  /* REVEAL */
  .reveal{opacity:0;transform:translateY(20px);transition:opacity .65s ease,transform .65s ease}
  .reveal.visible{opacity:1;transform:translateY(0)}

  /* RESPONSIVE */
  @media(max-width:768px){
    .ip-hero{
      background-image:linear-gradient(to bottom,rgba(10,10,10,0.70) 0%,rgba(10,10,10,0.85) 100%),url('/img/gallery/com-hero.jpg');
      background-position:center top;
      padding:72px 20px 56px;
    }
    .ip-hero-btns{flex-direction:column}
    .ip-hero-btns a{text-align:center;width:100%}
    .section-wrap{padding:64px 20px}
    .segments-grid,.ben-grid{grid-template-columns:1fr}
    #final-cta{padding:80px 20px}
    .final-cta-actions{flex-direction:column;align-items:center}
  }
</style>

<!-- INNER PAGE HERO -->
<section class="ip-hero">
  <div class="ip-hero-inner">
    <div class="section-label reveal">Sector Comercial</div>
    <h1 class="ip-hero-title reveal">PROTECCIÓN PARA<br><em>EMPRESAS.</em></h1>
    <p class="ip-hero-sub reveal">Si tiene múltiples ubicaciones en zonas de huracanes, cada tormenta es una amenaza multiplicada. Un solo programa corporativo para todas sus sucursales.</p>
    <div class="ip-hero-btns reveal">
      <a href="/cotizador" class="btn-white">Realizar una cotización</a>
      <a href="<%= site.whatsapp.url %>" class="btn-outline-white" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</section>

<!-- BENEFITS -->
<section class="section-wrap">
  <div class="reveal">
    <div class="section-label">Por qué nos eligen las empresas</div>
    <h2 class="section-title">UN SOLO PROVEEDOR.<br><em>TODAS SUS UBICACIONES.</em></h2>
  </div>
  <div class="ben-grid">
    <div class="ben-card reveal">
      
      <div class="ben-title">SISTEMA ESTANDARIZADO</div>
      <p class="ben-body">Un solo protocolo para todas sus sucursales. Su equipo de cada ubicación sabe exactamente qué hacer y cuándo sin depender de nadie externo cuando llega el aviso.</p>
    </div>
    <div class="ben-card reveal" style="transition-delay:.1s">
      
      <div class="ben-title">BAJO MANTENIMIENTO</div>
      <p class="ben-body">Capacitamos al personal de cada sucursal y entregamos manuales escritos. El sistema fue diseñado para desplegarse en horas con su propio equipo, sin especialistas externos.</p>
    </div>
    <div class="ben-card reveal" style="transition-delay:.2s">
      
      <div class="ben-title">DESCUENTOS DE SEGURO</div>
      <p class="ben-body">Nuestros sistemas son reconocidos por aseguradoras como medida de mitigación certificada. Para empresas con múltiples ubicaciones, el ahorro en primas puede ser muy significativo.</p>
    </div>
  </div>
</section>

<!-- SEGMENTS -->
<section class="section-wrap" style="background:var(--offwhite)">
  <div class="reveal">
    <div class="section-label">Sectores que atendemos</div>
    <h2 class="section-title">SI OPERA EN ZONA COSTERA,<br><em>PODEMOS AYUDARLE.</em></h2>
  </div>
  <div class="segments-grid">
    <div class="seg-card reveal">
      
      <div class="seg-title">AGENCIAS DE AUTOS</div>
      <p class="seg-body">Su inventario en el estacionamiento representa millones. Una tormenta puede destruirlo en minutos. Nuestros sistemas protegen su exhibición exterior con despliegue rápido antes del impacto.</p>
      <div class="seg-ex">Distribuidores · Agencias · Lotes de autos</div>
    </div>
    <div class="seg-card reveal" style="transition-delay:.1s">
      
      <div class="seg-title">HOSPITALES Y CLÍNICAS</div>
      <p class="seg-body">Una instalación de salud no puede cesar operaciones durante una emergencia. Nuestros sistemas están clasificados para instalaciones esenciales, mismo estándar que hospitales militares.</p>
      <div class="seg-ex">Hospitales · Clínicas · Centros médicos</div>
    </div>
    <div class="seg-card reveal" style="transition-delay:.2s">
      
      <div class="seg-title">DESARROLLOS INMOBILIARIOS</div>
      <p class="seg-body">Condominios en construcción o entrega, desarrollos turísticos y bienes raíces de lujo. Protección integrada desde el diseño o como retrofit. Un diferenciador que sus compradores valorarán.</p>
      <div class="seg-ex">Desarrolladoras · Administradoras · HOA</div>
    </div>
    <div class="seg-card reveal" style="transition-delay:.3s">
      <div class="seg-icon">🌧</div>
      <div class="seg-title">RAIN PROTECTION</div>
      <p class="seg-body">Toldos verticales enrollables para terrazas, restaurantes y áreas abiertas. Protección contra lluvia, arena y sol sin estructura permanente.</p>
      <div class="seg-ex">Terrazas · Restaurantes · Pérgolas</div>
    </div>
  </div>
</section>


<!-- PRODUCTS -->

