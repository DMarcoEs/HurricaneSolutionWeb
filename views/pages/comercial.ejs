  .feat-cards {
    display: flex; gap: 4px; overflow: hidden;
    float: left; width: calc(100% - 420px);
  }
  .feat-card {
    position: relative; overflow: hidden; flex: 1;
    min-height: 280px; cursor: pointer;
  }
  .feat-card img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform .5s ease; filter: brightness(.55);
  }
  .feat-card:hover img { transform: scale(1.05); filter: brightness(.75); }
  .feat-card-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 20px 16px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px; letter-spacing: .04em; color: #fff;
    background: linear-gradient(to top, rgba(0,0,0,.7), transparent);
  }
  .feat-card-label em {
    font-style: normal; color: #24b7db; display: block;
    font-size: 11px; font-family: 'Lato', sans-serif;
    font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 4px; opacity: .8;
  }
  .feat-clearfix { clear: both; }

  /* ── GALERÍA ─────────────────────────────────── */
  #hs-gallery { background: #0a0a0a; padding: 80px 0; }
  .gal-header { padding: 0 64px 40px; }
  .gal-eyebrow {
    font-size: 10px; font-weight: 700; letter-spacing: .22em;
    text-transform: uppercase; color: #24b7db;
    display: flex; align-items: center; gap: 12px; margin-bottom: 14px;
  }
  .gal-eyebrow::before { content:''; width:28px; height:1px; background:#24b7db; box-shadow:0 0 6px rgba(36,183,219,.6); }
  .gal-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(36px,5vw,64px); line-height:.93; letter-spacing:.02em; color:#fff;
  }
  .gal-title em { font-style:normal; color:#24b7db; }
  .gal-stage { position: relative; width: 100%; background: #0a0a0a; }
  .gal-frame {
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 4px; padding: 0 64px;
    opacity: 0; transition: opacity .7s ease;
  }
  .gal-frame.active { display: grid; opacity: 1; }
  .gal-frame img { width: 100%; height: auto; display: block; cursor: zoom-in; }
  .gal-footer {
    display: flex; align-items: center;
    justify-content: space-between; padding: 16px 64px 0;
  }
  .gal-left { display: flex; align-items: center; gap: 20px; }
  .gal-counter { font-family: 'Bebas Neue', sans-serif; font-size: 14px; letter-spacing:.15em; color:#444; }
  .gal-counter span { color: #24b7db; }
  .gal-dots { display: flex; gap: 7px; align-items: center; }
  .gal-dot { width:22px; height:2px; background:#2a2a2a; cursor:pointer; transition:all .3s; }
  .gal-dot.active { background:#24b7db; width:36px; box-shadow:0 0 6px rgba(36,183,219,.5); }
  .gal-arrows { display: flex; gap: 8px; }
  .gal-arrow {
    width:44px; height:44px; border:1px solid #2a2a2a; background:transparent;
    color:#666; cursor:pointer; display:flex; align-items:center;
    justify-content:center; font-size:18px; transition:all .2s;
  }
  .gal-arrow:hover { border-color:#24b7db; color:#24b7db; box-shadow:0 0 10px rgba(36,183,219,.3); }

  @media(max-width: 900px) {
    #hs-features { padding: 56px 20px; }
    .feat-cards { float:none; width:100%; margin-bottom:32px; }
    .feat-header { float:none; width:100%; padding-left:0; max-width:100%; }
    .gal-header { padding:0 20px 32px; }
    .gal-frame { grid-template-columns:1fr; padding:0 20px; }
    .gal-footer { padding:14px 20px 0; }
  }
</style>

