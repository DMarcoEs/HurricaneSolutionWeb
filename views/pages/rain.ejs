<%# Rain Protection — Hurricane Solution — diseño premium v2 %>

<style>
  /* SECTIONS */
  .section-wrap{padding:100px 48px}
  .section-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--gray-500);margin-bottom:16px;display:flex;align-items:center;gap:10px}
  .section-label::before{content:'';display:block;width:24px;height:1px;background:var(--gray-500)}
  .section-title{font-family:var(--font-display);font-size:clamp(36px,4vw,60px);line-height:1;letter-spacing:.02em;margin-bottom:16px}
  .section-title em{font-style:normal;color:var(--accent)}
  .section-body{font-size:15px;font-weight:400;color:var(--gray-800);line-height:1.75;max-width:720px}

  /* RAIN HERO — tratamiento especial azul lluvia */
  .ip-hero{
    background: #080e14;
    background-image:
      linear-gradient(135deg, rgba(8,14,20,0.82) 35%, rgba(8,14,20,0.55) 100%),
      url('/img/hs-rain-hero.png');
    background-size:cover;
    background-repeat:no-repeat;
    background-position:center;
    padding:100px 48px 80px;
    position:relative;
    overflow:hidden;
  }
  .ip-hero::before{
    content:'';position:absolute;inset:0;
    background:radial-gradient(ellipse 80% 60% at 10% 80%, rgba(36,183,219,.10), transparent);
    pointer-events:none;
  }
  .ip-hero-inner{max-width:760px;position:relative;z-index:1}
  .ip-hero .section-label{color:var(--accent);letter-spacing:.3em}
  .ip-hero .section-label::before{background:var(--accent)}
  .ip-hero-title{font-family:var(--font-display);font-size:clamp(42px,6vw,80px);line-height:1;letter-spacing:.02em;color:var(--white);margin-bottom:20px}
  .ip-hero-title em{font-style:normal;color:var(--accent)}
  .ip-hero-sub{font-size:16px;font-weight:400;color:rgba(255,255,255,.92);line-height:1.75;max-width:580px;margin-bottom:36px}
  .ip-hero-btns{display:flex;gap:12px;flex-wrap:wrap}

  /* BENEFITS */
  .ben-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:56px}
  .ben-card{background:var(--offwhite);border:1px solid var(--gray-200);padding:48px 40px;transition:border-color .3s,background .3s}
  .ben-card:hover{border-color:var(--black);background:var(--white)}
  .ben-icon{font-size:28px;margin-bottom:20px;display:block}
  .ben-title{font-family:var(--font-display);font-size:22px;letter-spacing:.04em;color:var(--black);margin-bottom:12px}
  .ben-body{font-size:13px;font-weight:400;color:var(--gray-800);line-height:1.75}

  /* DARK SECTION — sistemas */
  .section-wrap-dark{padding:100px 48px;background:var(--black);color:var(--white)}
  .section-wrap-dark .section-label{color:var(--gray-600)}
  .section-wrap-dark .section-label::before{background:var(--gray-600)}
  .section-wrap-dark .section-title{color:var(--white)}
  .section-wrap-dark .ben-card{background:rgba(255,255,255,.04);border:1px solid var(--gray-800)}
  .section-wrap-dark .ben-card:hover{border-color:var(--accent);background:rgba(255,255,255,.06)}
  .section-wrap-dark .ben-title{color:var(--white)}
  .section-wrap-dark .ben-body{color:var(--gray-200)}
  .way-num{font-family:var(--font-display);font-size:48px;letter-spacing:.04em;color:var(--accent);line-height:1;margin-bottom:24px}

  /* SEGMENTS */
  .segments-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:56px}
  .seg-card{background:var(--white);border:1px solid var(--gray-200);padding:48px 40px;transition:border-color .3s}
  .seg-card:hover{border-color:var(--black)}
  .seg-icon{width:48px;height:48px;background:var(--black);margin-bottom:28px;display:flex;align-items:center;justify-content:center;font-size:22px}
  .seg-title{font-family:var(--font-display);font-size:26px;letter-spacing:.03em;color:var(--black);margin-bottom:12px;line-height:1.1}
  .seg-body{font-size:13px;font-weight:400;color:var(--black);line-height:1.7}

  /* FINAL CTA */
  #final-cta{background:var(--black);padding:120px 48px;text-align:center;position:relative;overflow:hidden}
  .final-cta-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 100%,rgba(36,183,219,.07),transparent);pointer-events:none}
  .final-cta-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:24px;position:relative}
  .final-cta-title{font-family:var(--font-display);font-size:clamp(48px,7vw,100px);line-height:.95;letter-spacing:.01em;color:var(--white);margin-bottom:24px;position:relative}
  .final-cta-sub{font-size:15px;font-weight:400;color:var(--white);line-height:1.7;max-width:560px;margin:0 auto 48px;position:relative}
  .final-cta-actions{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;position:relative}
  .btn-white{position:relative;overflow:hidden;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:rgba(36,183,219,.05);color:var(--white);border:1px solid rgba(36,183,219,.2);border-radius:9999px;padding:14px 36px;text-decoration:none;display:inline-block;transition:background .2s,border-color .3s}
  .btn-white::before{content:'';position:absolute;top:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(36,183,219,.8),transparent);opacity:0;transition:opacity .4s}
  .btn-white::after{content:'';position:absolute;bottom:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(36,183,219,.5),transparent);opacity:0;transition:opacity .4s}
  .btn-white:hover{background:rgba(36,183,219,.0);border-color:rgba(36,183,219,.35);color:var(--white)}
  .btn-white:hover::before,.btn-white:hover::after{opacity:1}
  .btn-outline-white{position:relative;overflow:hidden;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:rgba(37,211,102,.05);color:#fff;border:1px solid rgba(37,211,102,.25);border-radius:9999px;padding:14px 36px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:background .2s,border-color .3s}
  .btn-outline-white::before{content:'';position:absolute;top:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(37,211,102,.8),transparent);opacity:0;transition:opacity .4s}
  .btn-outline-white::after{content:'';position:absolute;bottom:0;left:12.5%;width:75%;height:1px;background:linear-gradient(to right,transparent,rgba(37,211,102,.5),transparent);opacity:0;transition:opacity .4s}
  .btn-outline-white:hover{background:rgba(37,211,102,.0);border-color:rgba(37,211,102,.4);color:#fff}
  .btn-outline-white:hover::before,.btn-outline-white:hover::after{opacity:1}

  /* REVEAL */
  .reveal{opacity:0;transform:translateY(20px);transition:opacity .65s ease,transform .65s ease}
  .reveal.visible{opacity:1;transform:translateY(0)}

  /* RESPONSIVE */
  @media(max-width:768px){
    .ip-hero{
      background-image:
        linear-gradient(to bottom, rgba(8,14,20,0.93) 0%, rgba(12,30,50,0.88) 100%),
        url('/img/hs-rain-hero-mobile.jpg');
      background-position:center top;
      padding:72px 20px 56px;
    }
    .ip-hero-btns{flex-direction:column}
    .ip-hero-btns a{text-align:center;width:100%}
    .section-wrap,.section-wrap-dark{padding:64px 20px}
    .ben-grid,.segments-grid{grid-template-columns:1fr}
    #final-cta{padding:80px 20px}
    .final-cta-actions{flex-direction:column;align-items:center}
  }
</style>

<!-- INNER PAGE HERO -->
<section class="ip-hero">
  <div class="ip-hero-inner">
    <div class="section-label reveal">Rain Protection</div>
    <h1 class="ip-hero-title reveal">HS <em>RAIN PROTECTION.</em></h1>
    <p class="ip-hero-sub reveal">Protección contra lluvia, arena y sol para terrazas, restaurantes, pergolas y áreas abiertas. Tres sistemas de operación para adaptarse a cualquier espacio y presupuesto.</p>
    <div class="ip-hero-btns reveal">
      <a href="/cotizador" class="btn-white">Realizar una cotización</a>
      <a href="<%= site.whatsapp.url %>" class="btn-outline-white" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</section>

<!-- BENEFITS -->
<section class="section-wrap">
  <div class="reveal">
    <div class="section-label">Por qué nos eligen</div>
    <h2 class="section-title">TRES VENTAJAS<br><em>QUE IMPORTAN.</em></h2>
  </div>
  <div class="ben-grid">
    <div class="ben-card reveal">
      
      <div class="ben-title">MÁS DÍAS DE OPERACIÓN</div>
      <p class="ben-body">Sus áreas exteriores siguen funcionando durante lluvia intensa. Más mesas, más clientes, más ingresos, sin importar el clima. Para hoteles y restaurantes esto se traduce directamente en resultados.</p>
    </div>
    <div class="ben-card reveal" style="transition-delay:.1s">
      
      <div class="ben-title">SIN COMPROMETER EL ESPACIO</div>
      <p class="ben-body">Diseñado para integrarse a la arquitectura. Cuando no lo necesita, permanece recogido ordenadamente. Cuando lo necesita, se despliega en minutos sin herramientas especiales.</p>
    </div>
    <div class="ben-card reveal" style="transition-delay:.2s">
      
      <div class="ben-title">BAJO MANTENIMIENTO</div>
      <p class="ben-body">Tela técnica resistente a UV, humedad y salinidad. Solo lavado ocasional con agua y jabón. No se oxida, no se decolora. Diseñado para el clima costero de México.</p>
    </div>
  </div>
</section>

<!-- SISTEMAS — sección oscura distintiva -->
<section class="section-wrap-dark">
  <div class="reveal">
    <div class="section-label">Opciones de instalación</div>
    <h2 class="section-title">DOS SISTEMAS.<br><em>UNA SOLUCIÓN A SU MEDIDA.</em></h2>
  </div>
  <div class="ben-grid">
    <div class="ben-card reveal">
      <div class="way-num">01</div>
      <div class="ben-title">SISTEMA MECÁNICO</div>
      <p class="ben-body">Mayor comodidad para áreas medianas. Despliegue eficiente sin esfuerzo físico. Ideal para terrazas de hotel, restaurantes y áreas de piscina de uso intensivo.</p>
    </div>
    <div class="ben-card reveal" style="transition-delay:.1s">
      <div class="way-num">02</div>
      <div class="ben-title">SISTEMA ELÉCTRICO</div>
      <p class="ben-body">Despliegue automático con control remoto. Para espacios donde la comodidad es prioridad. Puede programarse con sensores de lluvia para despliegue automático.</p>
    </div>
  </div>
</section>

<!-- APPLICATIONS -->
<section class="section-wrap" style="background:var(--offwhite)">
  <div class="reveal">
    <div class="section-label">Aplicaciones</div>
    <h2 class="section-title">¿DÓNDE LO<br><em>NECESITA?</em></h2>
  </div>
  <div class="segments-grid">
    <div class="seg-card reveal">
      
      <div class="seg-title">HOTELES</div>
      <p class="seg-body">Protección para terrazas, restaurantes, bares y áreas de alberca. Mantenga sus espacios exteriores operativos durante la temporada de lluvias.</p>
    </div>
    <div class="seg-card reveal" style="transition-delay:.1s">
      
      <div class="seg-title">RESTAURANTES</div>
      <p class="seg-body">Más mesas disponibles todo el año. Incluso durante lluvia intensa, sus clientes disfrutan del exterior.</p>
    </div>
    <div class="seg-card reveal" style="transition-delay:.2s">
      
      <div class="seg-title">RESIDENCIAL</div>
      <p class="seg-body">Ideal para patios, balcones, pérgolas y penthouses. Disfrute sus espacios exteriores sin importar el clima.</p>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section id="final-cta">
  <div class="final-cta-bg"></div>
  <div class="final-cta-label reveal">Cotización gratuita</div>
  <h2 class="final-cta-title reveal">PROTEJA SUS ESPACIOS<br>EXTERIORES.</h2>
  <p class="final-cta-sub reveal">Solicite una cotización gratuita para su terraza, restaurante o área exterior.</p>
  <div class="final-cta-actions reveal">
    <a class="btn-white" href="/contacto">Realizar una cotización</a>
    <a class="btn-outline-white" href="<%= site.whatsapp.url %>" target="_blank" rel="noopener">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.849L0 24l6.335-1.652A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.814 9.814 0 01-5.016-1.378l-.36-.214-3.732.979.994-3.636-.235-.374A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
      WhatsApp
    </a>
  </div>
</section>

<script>
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(function(el) { obs.observe(el); });
</script>
