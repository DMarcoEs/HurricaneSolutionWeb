<style>
  .dash-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }
  .dash-stats {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
  }
  .dash-stat {
    background: #111;
    border: 1px solid #222;
    padding: 20px 28px;
    flex: 1;
    text-align: center;
  }
  .dash-stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    color: #24b7db;
    line-height: 1;
  }
  .dash-stat-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: #666;
    margin-top: 4px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #24b7db;
    color: #000;
    padding: 12px 24px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: 'Lato', sans-serif;
    transition: opacity .2s;
  }
  .btn-primary:hover { opacity: .85; }

  .posts-table {
    width: 100%;
    border-collapse: collapse;
    background: #111;
    border: 1px solid #222;
  }
  .posts-table th {
    text-align: left;
    padding: 14px 16px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: #555;
    border-bottom: 1px solid #222;
    background: #0a0a0a;
  }
  .posts-table td {
    padding: 16px;
    font-size: 14px;
    color: #ccc;
    border-bottom: 1px solid #1a1a1a;
    vertical-align: middle;
  }
  .posts-table tr:hover td { background: rgba(255,255,255,.02); }

  .post-title-cell {
    font-weight: 600;
    color: #fff;
    max-width: 360px;
  }
  .post-title-cell a {
    color: #fff;
    text-decoration: none;
    transition: color .2s;
  }
  .post-title-cell a:hover { color: #24b7db; }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .badge-pub  { background: rgba(36,183,219,.15); color: #24b7db; border: 1px solid rgba(36,183,219,.3); }
  .badge-draft{ background: rgba(255,255,255,.06); color: #888;   border: 1px solid #333; }

  .actions { display: flex; gap: 8px; }
  .btn-edit {
    padding: 7px 14px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: none;
    border: 1px solid #333;
    color: #aaa;
    text-decoration: none;
    font-family: 'Lato', sans-serif;
    cursor: pointer;
    transition: border-color .2s, color .2s;
  }
  .btn-edit:hover { border-color: #fff; color: #fff; }
  .btn-delete {
    padding: 7px 14px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    background: none;
    border: 1px solid #333;
    color: #888;
    cursor: pointer;
    font-family: 'Lato', sans-serif;
    transition: border-color .2s, color .2s;
  }
  .btn-delete:hover { border-color: #e53935; color: #e53935; }

  .empty-state {
    text-align: center;
    padding: 80px 32px;
    color: #555;
    background: #111;
    border: 1px solid #222;
  }
  .empty-state-icon { font-size: 48px; margin-bottom: 16px; }
  .empty-state-text { font-size: 15px; }
</style>

<div class="dash-header">
  <div></div>
  <a href="/admin/post/new" class="btn-primary">✏️ &nbsp;Nuevo Post</a>
</div>

<%
  const total = posts.length;
  const published = posts.filter(p => p.status === 'published').length;
  const drafts = posts.filter(p => p.status === 'draft').length;
%>
<div class="dash-stats">
  <div class="dash-stat">
    <div class="dash-stat-num"><%= total %></div>
    <div class="dash-stat-label">Total Posts</div>
  </div>
  <div class="dash-stat">
    <div class="dash-stat-num"><%= published %></div>
    <div class="dash-stat-label">Publicados</div>
  </div>
  <div class="dash-stat">
    <div class="dash-stat-num"><%= drafts %></div>
    <div class="dash-stat-label">Borradores</div>
  </div>
</div>

<% if (posts.length === 0) { %>
  <div class="empty-state">
    <div class="empty-state-icon">📝</div>
    <div class="empty-state-text">Aún no hay posts. <a href="/admin/post/new" style="color:#24b7db">Crea el primero →</a></div>
  </div>
<% } else { %>
  <table class="posts-table">
    <thead>
      <tr>
        <th>Título</th>
        <th>Categoría</th>
        <th>Estado</th>
        <th>Fecha</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% posts.forEach(function(post) { %>
      <tr>
        <td class="post-title-cell">
          <a href="/blog/<%= post.slug %>" target="_blank"><%= post.title %></a>
        </td>
        <td><%= post.category || '—' %></td>
        <td>
          <% if (post.status === 'published') { %>
            <span class="badge badge-pub">Publicado</span>
          <% } else { %>
            <span class="badge badge-draft">Borrador</span>
          <% } %>
        </td>
        <td><%= post.date %></td>
        <td>
          <div class="actions">
            <a href="/admin/post/edit/<%= post.id %>" class="btn-edit">Editar</a>
            <form action="/admin/post/delete/<%= post.id %>" method="POST"
                  onsubmit="return confirm('¿Eliminar «<%= post.title %>»? Esta acción no se puede deshacer.')">
              <button type="submit" class="btn-delete">Eliminar</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
