<!doctype html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Acceso Admin · Hurricane Solution</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #0a0a0a; --white: #fff; --accent: #24b7db;
      --gray-400: #9e9e9e; --gray-800: #222;
    }
    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Lato', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-box {
      width: 100%;
      max-width: 400px;
      padding: 48px 40px;
      background: #111;
      border: 1px solid var(--gray-800);
    }
    .login-logo {
      text-align: center;
      margin-bottom: 32px;
    }
    .login-logo img { height: 48px; width: auto; }
    .login-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--accent);
      text-align: center;
      margin-top: 10px;
    }
    .login-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 32px;
      letter-spacing: .04em;
      text-align: center;
      margin-bottom: 32px;
    }
    .login-error {
      background: rgba(220,50,50,.1);
      border: 1px solid #dc3232;
      color: #ff6b6b;
      padding: 12px 16px;
      font-size: 13px;
      margin-bottom: 20px;
    }
    label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--gray-400);
      margin-bottom: 8px;
    }
    input[type="password"] {
      width: 100%;
      background: var(--black);
      border: 1px solid var(--gray-800);
      color: var(--white);
      padding: 14px 16px;
      font-size: 16px;
      font-family: 'Lato', sans-serif;
      outline: none;
      transition: border-color .2s;
      margin-bottom: 24px;
    }
    input[type="password"]:focus { border-color: var(--accent); }
    button[type="submit"] {
      width: 100%;
      background: var(--accent);
      color: var(--black);
      border: none;
      padding: 16px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      font-family: 'Lato', sans-serif;
      cursor: pointer;
      transition: opacity .2s;
    }
    button[type="submit"]:hover { opacity: .85; }
  </style>
</head>
<body>
  <div class="login-box">
    <div class="login-logo">
      <img src="/img/hs-logo.png" alt="Hurricane Solution" />
      <div class="login-label">Panel de Administración</div>
    </div>
    <div class="login-title">ACCESO</div>

    <% if (error) { %>
      <div class="login-error"><%= error %></div>
    <% } %>

    <form action="/admin/login" method="POST">
      <label for="password">Contraseña</label>
      <input type="password" id="password" name="password" autofocus autocomplete="current-password" />
      <button type="submit">Entrar</button>
    </form>
  </div>
</body>
</html>
